{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pdf_translate: one_page",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/src/translate/pdf_translate.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "--input",
        "tests/data/one_page.pdf",
        "--output-dir",
        "tests/data/output/one_page",
        "--clear"
      ]
    },
    {
      "name": "pdf_translate: one_page OCR only",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/src/translate/pdf_translate.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "--input",
        "tests/data/book.pdf",
        "--output-dir",
        "tests/data/output/book_test",
        "--clear",
        "--annotation-mode", "page",
        "--ocr-model", "chandra",
        "--translation-base-url", "http://192.168.3.105:11434/v1"
      ]
    }
  ]
}
